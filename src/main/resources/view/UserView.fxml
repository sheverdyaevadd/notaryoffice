<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.notary.controller.UserController"
      spacing="12">

    <Label text="Пользователи"/>

    <HBox spacing="8">
        <Button text="← Назад" onAction="#handleGoToClients"/>
        <Button text="Добавить" onAction="#handleAdd"/>
        <Button text="Редактировать" onAction="#handleEdit"/>
        <Button text="Удалить" onAction="#handleDelete"/>
    </HBox>

    <TableView fx:id="userTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colLogin" text="Логин" prefWidth="150"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="200"/>
            <TableColumn fx:id="colPhone" text="Телефон" prefWidth="130"/>
            <TableColumn fx:id="colRole" text="Роль" prefWidth="120"/>
        </columns>
    </TableView>

    <Label fx:id="statusLabel"/>

</VBox>