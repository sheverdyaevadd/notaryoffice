<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.notary.controller.DealController"
      spacing="12">

    <Label text="Сделки"/>

    <HBox spacing="8">
        <Button text="←Клиенты" onAction="#handleGoToClients"/>
        <Button text="Добавить" onAction="#handleAdd"/>
        <Button text="Редактировать" onAction="#handleEdit"/>
        <Button text="Удалить" onAction="#handleDelete"/>
        <Button text="Выйти" onAction="#handleLogout"/>
    </HBox>

    <TableView fx:id="dealTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colClient" text="ID клиента" prefWidth="100"/>
            <TableColumn fx:id="colDate" text="Дата" prefWidth="160"/>
            <TableColumn fx:id="colAmount" text="Сумма" prefWidth="120"/>
            <TableColumn fx:id="colCommission" text="Комиссия" prefWidth="120"/>
        </columns>
    </TableView>

    <Label fx:id="statusLabel"/>

</VBox>