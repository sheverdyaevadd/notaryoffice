<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.notary.controller.ProvidedServiceController"
      spacing="12">

    <Label text="Оказанные услуги"/>

    <HBox spacing="8">
        <Button text="← Назад" onAction="#handleGoToClients"/>
        <Button fx:id="btnAdd" text="Добавить" onAction="#handleAdd"/>
        <Button fx:id="btnEdit" text="Редактировать" onAction="#handleEdit"/>
        <Button fx:id="btnDelete" text="Удалить" onAction="#handleDelete"/>
        <Button text="Выйти" onAction="#handleLogout"/>
    </HBox>

    <TableView fx:id="providedServiceTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
            <TableColumn fx:id="colDeal" text="ID сделки" prefWidth="100"/>
            <TableColumn fx:id="colService" text="ID услуги" prefWidth="100"/>
            <TableColumn fx:id="colDiscount" text="ID скидки" prefWidth="100"/>
            <TableColumn fx:id="colDate" text="Дата" prefWidth="160"/>
            <TableColumn fx:id="colPrice" text="Итоговая стоимость" prefWidth="150"/>
        </columns>
    </TableView>

    <Label fx:id="statusLabel"/>

</VBox>